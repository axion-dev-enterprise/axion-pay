{
  "name": "axion-pay-payment",
  "version": "1.0.0",
  "description": "Payment Service API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start:frontend": "vite --config vite.config.js",
    "start:backend": "node src/index.js",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "dev": "npm run start",
    "dev:frontend": "npm run start:frontend",
    "dev:backend": "npm run start:backend",
    "gen:assets": "node scripts/generate-webapp-public-assets.cjs",
    "prestart:frontend": "npm run gen:assets",
    "preweb:build": "npm run gen:assets",
    "web:build": "vite build --config vite.config.js",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run web:build",
    "start:prod": "npm run build && node src/index.js",
    "pretest": "npm install",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:web": "vitest run",
    "test:payments": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js src/controllers/paymentController.test.js",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "framer-motion": "^12.23.24",
    "helmet": "^7.1.0",
    "lucide-react": "^0.542.0",
    "multer": "^1.4.5-lts",
    "nodemailer": "^6.9.13",
    "pino": "^8.16.0",
    "pino-http": "^8.5.1",
    "pino-pretty": "^10.2.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "react-router-dom": "^6.30.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uuid": "^9.0.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "jsdom": "^26.1.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "png-to-ico": "^2.1.0",
    "pngjs": "^7.0.0",
    "supertest": "^7.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=24.6.0 <26"
  }
}
